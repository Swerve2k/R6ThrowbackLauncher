<Window x:Class="R6ThrowbackLauncher.EditUsernameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Username"
        Height="180" Width="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#15151F" CornerRadius="8" BorderBrush="#DC143C" BorderThickness="1">
        <StackPanel Margin="24">
            <TextBlock x:Name="TitleText" Text="Edit Username"
                       Foreground="White" FontSize="15" FontWeight="Bold" Margin="0,0,0,14"/>
            <TextBox x:Name="UsernameInput"
                     Height="34" Background="#101018" Foreground="White"
                     BorderBrush="#22222F" BorderThickness="1"
                     Padding="10,0" FontSize="13" CaretBrush="White"
                     MaxLength="16" Margin="0,0,0,16"
                     KeyDown="UsernameInput_KeyDown"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="CANCEL" Width="80" Height="30" Margin="0,0,10,0"
                        Background="#22222F" Foreground="#AAAAAA" BorderThickness="0"
                        Cursor="Hand" FontSize="12" FontWeight="Bold"
                        Click="Cancel_Click"/>
                <Button Content="SAVE" Width="80" Height="30"
                        Background="#DC143C" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontSize="12" FontWeight="Bold"
                        Click="Save_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
