<Window x:Class="R6ThrowbackLauncher.DetectedInstallsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Detected Installs"
        Height="520" Width="620"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#0D0D14" CornerRadius="10" BorderBrush="#DC143C" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>
        <Grid Margin="28">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Margin="0,0,0,12">
                <TextBlock Text="📦  Downloaded Versions Detected"
                           Foreground="White" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="The following game folders were found. Select which ones to import into your library."
                           Foreground="#AAAAAA" FontSize="13" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>

            <Separator Grid.Row="1" Background="#1A1A25" Margin="0,0,0,10"/>

            <!-- Select All / Deselect All -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                <Button Content="Select All" Width="100" Height="28" Margin="0,0,10,0"
                        Background="#1A1A25" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontSize="12" Click="SelectAll_Click"/>
                <Button Content="Deselect All" Width="100" Height="28"
                        Background="#1A1A25" Foreground="#AAAAAA" BorderThickness="0"
                        Cursor="Hand" FontSize="12" Click="DeselectAll_Click"/>
                <TextBlock x:Name="CountLabel" Text="" Foreground="#555566"
                           FontSize="12" VerticalAlignment="Center" Margin="14,0,0,0"/>
            </StackPanel>

            <!-- Folder list -->
            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="FolderListPanel"/>
            </ScrollViewer>

            <!-- Buttons -->
            <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
                <Button Content="SKIP" Width="90" Height="34" Margin="0,0,10,0"
                        Background="#1A1A25" Foreground="#AAAAAA" BorderThickness="0"
                        Cursor="Hand" FontSize="13" FontWeight="Bold"
                        Click="Skip_Click"/>
                <Button x:Name="ImportButton" Content="IMPORT SELECTED (0)" Height="34" Padding="18,0"
                        Background="#DC143C" Foreground="White" BorderThickness="0"
                        Cursor="Hand" FontSize="13" FontWeight="Bold"
                        Click="Import_Click"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
