<Window x:Class="R6ThrowbackLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Operation Throwback"
        Height="900" Width="1400"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Window.Resources>
        <LinearGradientBrush x:Key="RiotBackground" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#0A0A0F" Offset="0"/>
            <GradientStop Color="#111118" Offset="0.5"/>
            <GradientStop Color="#0D0D14" Offset="1"/>
        </LinearGradientBrush>

        <Style x:Key="RiotButton" TargetType="Button">
            <Setter Property="Background" Value="#DC143C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="30,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <Border.RenderTransform><ScaleTransform ScaleX="1" ScaleY="1"/></Border.RenderTransform>
                            <Border.RenderTransformOrigin><Point X="0.5" Y="0.5"/></Border.RenderTransformOrigin>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FF1744"/>
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#DC143C" BlurRadius="30" ShadowDepth="0" Opacity="0.8"/>
                                    </Setter.Value>
                                </Setter>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleX)" To="1.0" Duration="0:0:0.15"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(RenderTransform).(ScaleTransform.ScaleY)" To="1.0" Duration="0:0:0.15"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="RenderTransform">
                                    <Setter.Value><ScaleTransform ScaleX="0.98" ScaleY="0.98"/></Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#888888"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="20,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                BorderThickness="0,0,3,0" BorderBrush="Transparent">
                            <ContentPresenter Margin="{TemplateBinding Padding}" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="Background" Value="#15151F"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource Self}, Path=Tag}" Value="Selected">
                                <Setter Property="Foreground" Value="#DC143C"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#DC143C"/>
                                <Setter TargetName="border" Property="Background" Value="#1A1A25"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ContentView" TargetType="Grid">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        </Style>

        <Style x:Key="GameCard" TargetType="Border">
            <Setter Property="Background" Value="#15151F"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,25,25"/>
            <Setter Property="Width" Value="260"/>
            <Setter Property="Height" Value="360"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#1C1C28"/>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="#DC143C" BlurRadius="25" ShadowDepth="0" Opacity="0.4"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border x:Name="MainWindowBorder" Background="{StaticResource RiotBackground}" CornerRadius="12"
            BorderBrush="Transparent" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="0" Opacity="0.9"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR -->
            <Border Grid.Column="0" Background="#0D0D14" CornerRadius="12,0,0,12"
                    BorderBrush="#1A1A25" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="80"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" VerticalAlignment="Center" Margin="20,0">
                        <TextBlock Text="OPERATION" FontFamily="Arial Black" FontSize="16" Foreground="#DC143C"/>
                        <TextBlock Text="THROWBACK" FontFamily="Arial Black" FontSize="20" Foreground="White" Margin="0,-5,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="0,20,0,0">
                        <Button x:Name="NavLibrary"   Content="🎮  LIBRARY"     Style="{StaticResource NavButton}" Click="NavLibrary_Click"    Tag="Selected"/>
                        <Button x:Name="NavDownload"  Content="⬇️  DOWNLOAD"    Style="{StaticResource NavButton}" Click="NavDownload_Click"/>
                        <Button x:Name="NavTools"     Content="🔧  TOOLS"       Style="{StaticResource NavButton}" Click="NavTools_Click"/>
                        <Button x:Name="NavChangelogs" Content="📋  CHANGELOGS" Style="{StaticResource NavButton}" Click="NavChangelogs_Click"/>
                        <Button x:Name="NavSettings"  Content="⚙️  SETTINGS"   Style="{StaticResource NavButton}" Click="NavSettings_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="20,20">
                        <Separator Background="#1A1A25" Margin="0,0,0,15"/>
                        <Button Content="📖  Guide"            Style="{StaticResource NavButton}" Padding="0" Height="35" Click="NavGuide_Click"/>
                        <Button Content="👥  Credits"          Style="{StaticResource NavButton}" Padding="0" Height="35" Click="NavCredits_Click"/>
                        <Button Content="🔄  Check for Updates" Style="{StaticResource NavButton}" Padding="0" Height="35" Click="CheckForUpdates_Click"/>
                        <TextBlock Text="v0.2.0" Foreground="#444444" FontSize="11" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- RIGHT CONTENT -->
            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="60"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- TOP BAR -->
                <Border Grid.Row="0" Background="#0D0D14" CornerRadius="0,12,0,0"
                        BorderBrush="#1A1A25" BorderThickness="0,0,0,1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="30,0">
                            <TextBlock x:Name="UsernameDisplay" Text="Steam User"
                                       Foreground="White" FontSize="14" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                            <Button Content="─" Click="MinimizeButton_Click" Width="40" Height="40" Margin="5"
                                    Background="Transparent" Foreground="#888888" BorderThickness="0" FontSize="18" Cursor="Hand"/>
                            <Button x:Name="MaximizeButton" Content="□" Click="MaximizeButton_Click" Width="40" Height="40" Margin="5"
                                    Background="Transparent" Foreground="#888888" BorderThickness="0" FontSize="14" Cursor="Hand"/>
                            <Button Content="✕" Click="CloseButton_Click" Width="40" Height="40" Margin="5"
                                    Background="Transparent" Foreground="#888888" BorderThickness="0" FontSize="14" Cursor="Hand"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- VIEWS -->
                <Grid Grid.Row="1" Margin="30" ClipToBounds="True">

                    <!-- LIBRARY VIEW -->
                    <Grid x:Name="LibraryView" Visibility="Visible" Style="{StaticResource ContentView}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,30">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="YOUR LIBRARY" FontSize="28" FontWeight="Bold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <Button Grid.Column="1" Content="📂  DOWNLOAD FOLDER"
                                    Style="{StaticResource RiotButton}"
                                    Background="#1A1A25" Padding="16,10" FontSize="13"
                                    VerticalAlignment="Center" Margin="0,0,10,0"
                                    Click="OpenDownloadFolder_Click"/>
                            <Button Grid.Column="2" Content="📁  IMPORT FOLDER"
                                    Style="{StaticResource RiotButton}" Padding="18,10" FontSize="13"
                                    VerticalAlignment="Center" Click="ImportFolder_Click"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <WrapPanel x:Name="LibraryPanel" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </Grid>

                    <!-- DOWNLOAD VIEW -->
                    <Grid x:Name="DownloadView" Visibility="Collapsed" Style="{StaticResource ContentView}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="340"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left controls -->
                        <Grid Grid.Column="0" Margin="0,0,24,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,24">
                                <TextBlock Text="DOWNLOAD SEASON" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                <TextBlock Text="Select a season and patch, then hit download"
                                           FontSize="14" Foreground="#888888" Margin="0,5,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1">
                                <StackPanel Margin="0,0,0,14">
                                    <TextBlock Text="Steam Username" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                                    <TextBox x:Name="UsernameTextBox" Height="36" Background="#101018" Foreground="White"
                                             BorderBrush="#22222F" BorderThickness="1" Padding="10,0" FontSize="13" CaretBrush="White"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,14">
                                    <TextBlock Text="Max Downloads" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                                    <TextBox x:Name="MaxDownloadsTextBox" Height="36" Text="16" Background="#101018" Foreground="White"
                                             BorderBrush="#22222F" BorderThickness="1" Padding="10,0" FontSize="13" CaretBrush="White"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,0,24">
                                    <TextBlock Text="Season / Patch" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                                    <Button x:Name="SeasonPatchButton" Height="36" Background="#101018" Foreground="White"
                                            BorderBrush="#22222F" BorderThickness="1" HorizontalContentAlignment="Left"
                                            Padding="10,0" Cursor="Hand" Click="SeasonPatchButton_Click">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border x:Name="border" Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                    <ContentPresenter VerticalAlignment="Center"/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="border" Property="Background" Value="#18182A"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Button.Template>
                                        Select season...
                                    </Button>
                                    <Popup x:Name="SeasonPatchPopup" PlacementTarget="{Binding ElementName=SeasonPatchButton}"
                                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True" PopupAnimation="Slide">
                                        <Border Background="#15151F" BorderBrush="#22222F" BorderThickness="1"
                                                CornerRadius="6" MinWidth="320" MaxHeight="400">
                                            <Border.Effect>
                                                <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="2" Opacity="0.6"/>
                                            </Border.Effect>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto" MinHeight="200" MaxHeight="400">
                                                <ListBox x:Name="SeasonPatchListBox" Background="Transparent" BorderThickness="0"
                                                         Foreground="White" Padding="4" SelectionMode="Single"
                                                         SelectionChanged="SeasonPatchListBox_SelectionChanged"
                                                         MouseDoubleClick="SeasonPatchListBox_MouseDoubleClick">
                                                    <ListBox.ItemContainerStyle>
                                                        <Style TargetType="ListBoxItem">
                                                            <Setter Property="Padding" Value="12,10"/>
                                                            <Setter Property="Margin" Value="2"/>
                                                            <Setter Property="Cursor" Value="Hand"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="ListBoxItem">
                                                                        <Border x:Name="itemBorder" Background="Transparent" CornerRadius="4" Padding="{TemplateBinding Padding}">
                                                                            <ContentPresenter/>
                                                                        </Border>
                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                <Setter TargetName="itemBorder" Property="Background" Value="#1C1C28"/>
                                                                            </Trigger>
                                                                            <Trigger Property="IsSelected" Value="True">
                                                                                <Setter TargetName="itemBorder" Property="Background" Value="#252535"/>
                                                                                <Setter TargetName="itemBorder" Property="BorderBrush" Value="#DC143C"/>
                                                                                <Setter TargetName="itemBorder" Property="BorderThickness" Value="0,0,0,2"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </ListBox.ItemContainerStyle>
                                                    <ListBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" FontSize="13" Foreground="White"/>
                                                        </DataTemplate>
                                                    </ListBox.ItemTemplate>
                                                </ListBox>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                </StackPanel>
                                <Button x:Name="DownloadButton" Content="DOWNLOAD"
                                        Style="{StaticResource RiotButton}" HorizontalAlignment="Left"
                                        Click="DownloadButton_Click"/>
                            </StackPanel>
                        </Grid>

                        <!-- Right: Season Artwork Panel -->
                        <Border Grid.Column="1" Background="#15151F" CornerRadius="10" ClipToBounds="True" VerticalAlignment="Top">
                            <Grid>
                                <Border x:Name="DownloadArtworkPlaceholder" Height="380" Background="#0D0D14">
                                    <TextBlock Text="🎮" FontSize="60" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.2"/>
                                </Border>
                                <Image x:Name="DownloadArtworkImage" Height="380" Stretch="UniformToFill" Visibility="Collapsed"/>
                                <Border Height="380" VerticalAlignment="Bottom">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="Transparent" Offset="0.4"/>
                                            <GradientStop Color="#15151F" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <StackPanel VerticalAlignment="Bottom" Margin="16,0,16,16">
                                    <TextBlock x:Name="DownloadArtworkSeason" Text="Select a Season"
                                               Foreground="White" FontSize="20" FontWeight="Bold"
                                               FontFamily="Arial Black" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="DownloadArtworkPatch" Text=""
                                               Foreground="#DC143C" FontSize="13" Margin="0,3,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- TOOLS VIEW -->
                    <Grid x:Name="ToolsView" Visibility="Collapsed" Style="{StaticResource ContentView}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Margin="0,0,0,25">
                            <TextBlock Text="TOOLS" FontSize="28" FontWeight="Bold" Foreground="White"/>
                            <TextBlock Text="Downloads open in your browser" FontSize="13" Foreground="#888888" Margin="0,5,0,0"/>
                        </StackPanel>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <WrapPanel Orientation="Horizontal">
                                <Border Background="#15151F" CornerRadius="8" Margin="0,0,20,20" Width="280" Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="🔓" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="R6 Liberator" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Text="Y1S1 — Y4S4" Foreground="#DC143C" FontSize="12" Margin="0,3,0,0"/>
                                        <TextBlock Text="Unlock All and Custom Game Editor" Foreground="#AAAAAA" FontSize="12" Margin="0,6,0,14" TextWrapping="Wrap"/>
                                        <Button Content="⬇  DOWNLOAD" Style="{StaticResource RiotButton}" Padding="14,8" FontSize="12" HorizontalAlignment="Left"
                                                Tag="https://github.com/JOJOVAV/r6-tools/blob/main/R6_Liberator_0.0.0.22.exe" Click="ToolDownload_Click"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#15151F" CornerRadius="8" Margin="0,0,20,20" Width="280" Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="🔓" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="R6 Liberator 2" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Text="Y5S3 Shadow Legacy" Foreground="#DC143C" FontSize="12" Margin="0,3,0,0"/>
                                        <TextBlock Text="Unlock All and Custom Game Editor" Foreground="#AAAAAA" FontSize="12" Margin="0,6,0,14" TextWrapping="Wrap"/>
                                        <Button Content="⬇  DOWNLOAD" Style="{StaticResource RiotButton}" Padding="14,8" FontSize="12" HorizontalAlignment="Left"
                                                Tag="https://github.com/JOJOVAV/r6-tools/blob/main/R6Liberator2.exe" Click="ToolDownload_Click"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#15151F" CornerRadius="8" Margin="0,0,20,20" Width="280" Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="🎯" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="Y7S2 Vector Glare Unlock All" Foreground="White" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                                        <TextBlock Text="Requires: Cheat Engine" Foreground="#DC143C" FontSize="12" Margin="0,3,0,0"/>
                                        <TextBlock Text="Unlock all for Vector Glare patch" Foreground="#AAAAAA" FontSize="12" Margin="0,6,0,14" TextWrapping="Wrap"/>
                                        <Button Content="⬇  DOWNLOAD" Style="{StaticResource RiotButton}" Padding="14,8" FontSize="12" HorizontalAlignment="Left"
                                                Tag="https://github.com/JOJOVAV/r6-tools/blob/main/Y7S2.zip" Click="ToolDownload_Click"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#15151F" CornerRadius="8" Margin="0,0,20,20" Width="280" Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="☀️" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="Y7S4 Solar Raid Unlock All" Foreground="White" FontSize="16" FontWeight="Bold" TextWrapping="Wrap"/>
                                        <TextBlock Text="Requires: Cheat Engine" Foreground="#DC143C" FontSize="12" Margin="0,3,0,0"/>
                                        <TextBlock Text="Unlock all for Solar Raid patch" Foreground="#AAAAAA" FontSize="12" Margin="0,6,0,14" TextWrapping="Wrap"/>
                                        <Button Content="⬇  DOWNLOAD" Style="{StaticResource RiotButton}" Padding="14,8" FontSize="12" HorizontalAlignment="Left"
                                                Tag="https://github.com/JOJOVAV/r6-tools/blob/main/Y7S4.rar" Click="ToolDownload_Click"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#15151F" CornerRadius="8" Margin="0,0,20,20" Width="280" Padding="18">
                                    <StackPanel>
                                        <TextBlock Text="✂️" FontSize="28" Margin="0,0,0,8"/>
                                        <TextBlock Text="Shears" Foreground="White" FontSize="16" FontWeight="Bold"/>
                                        <TextBlock Text="by Lungu" Foreground="#DC143C" FontSize="12" Margin="0,3,0,0"/>
                                        <TextBlock Text="Modding tool for R6 Legacy builds" Foreground="#AAAAAA" FontSize="12" Margin="0,6,0,14" TextWrapping="Wrap"/>
                                        <Button Content="⬇  DOWNLOAD" Style="{StaticResource RiotButton}" Padding="14,8" FontSize="12" HorizontalAlignment="Left"
                                                Tag="https://github.com/lungu19/shears/releases/tag/0.2.0" Click="ToolDownload_Click"/>
                                    </StackPanel>
                                </Border>
                            </WrapPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- CHANGELOGS VIEW -->
                    <Grid x:Name="ChangelogsView" Visibility="Collapsed" Style="{StaticResource ContentView}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CHANGELOGS" FontSize="28" FontWeight="Bold" Foreground="White"/>
                                <TextBlock x:Name="ChangelogLastUpdated" Text="Loading..."
                                           FontSize="12" Foreground="#555566" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="🔄  REFRESH" Style="{StaticResource RiotButton}"
                                    Padding="16,10" FontSize="12" VerticalAlignment="Center"
                                    Click="RefreshChangelogs_Click"/>
                        </Grid>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel x:Name="ChangelogsPanel">
                                <Border Background="#15151F" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                                    <TextBlock Text="Loading changelogs..." Foreground="#555566" FontSize="14"/>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- SETTINGS VIEW -->
                    <Grid x:Name="SettingsView" Visibility="Collapsed" Style="{StaticResource ContentView}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="SETTINGS" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,30"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="560" HorizontalAlignment="Left">
                                <Border Background="#15151F" CornerRadius="8" Padding="24" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="STEAM USERNAME" Foreground="#DC143C" FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>
                                        <TextBlock Text="Used as your in-game name when launching a season."
                                                   Foreground="#888888" FontSize="12" Margin="0,0,0,14" TextWrapping="Wrap"/>
                                        <TextBox x:Name="SettingsSteamUsernameBox" Height="36"
                                                 Background="#101018" Foreground="White" BorderBrush="#22222F" BorderThickness="1"
                                                 Padding="10,0" FontSize="14" CaretBrush="White" Margin="0,0,0,12"/>
                                        <Button Content="SAVE USERNAME" Style="{StaticResource RiotButton}"
                                                Padding="20,10" FontSize="13" HorizontalAlignment="Left"
                                                Click="SaveUsername_Click"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#15151F" CornerRadius="8" Padding="24" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="THEME COLOR" Foreground="#DC143C" FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>
                                        <TextBlock Text="Customize the accent color used throughout the launcher."
                                                   Foreground="#888888" FontSize="12" Margin="0,0,0,18" TextWrapping="Wrap"/>
                                        <Border x:Name="ThemeColorPreview" Height="40" CornerRadius="6" Margin="0,0,0,20" Background="#DC143C">
                                            <TextBlock Text="PREVIEW" Foreground="White" FontSize="12" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/><ColumnDefinition Width="*"/><ColumnDefinition Width="35"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="R" Foreground="#FF4444" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <Slider x:Name="RedSlider" Grid.Column="1" Minimum="0" Maximum="255" Value="220"
                                                    VerticalAlignment="Center" Margin="8,0" ValueChanged="ThemeSlider_Changed"/>
                                            <TextBlock x:Name="RedValue" Grid.Column="2" Text="220" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/><ColumnDefinition Width="*"/><ColumnDefinition Width="35"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="G" Foreground="#44FF44" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <Slider x:Name="GreenSlider" Grid.Column="1" Minimum="0" Maximum="255" Value="20"
                                                    VerticalAlignment="Center" Margin="8,0" ValueChanged="ThemeSlider_Changed"/>
                                            <TextBlock x:Name="GreenValue" Grid.Column="2" Text="20" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Grid Margin="0,0,0,18">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="20"/><ColumnDefinition Width="*"/><ColumnDefinition Width="35"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="B" Foreground="#4488FF" FontWeight="Bold" VerticalAlignment="Center"/>
                                            <Slider x:Name="BlueSlider" Grid.Column="1" Minimum="0" Maximum="255" Value="60"
                                                    VerticalAlignment="Center" Margin="8,0" ValueChanged="ThemeSlider_Changed"/>
                                            <TextBlock x:Name="BlueValue" Grid.Column="2" Text="60" Foreground="White" FontSize="12" VerticalAlignment="Center"/>
                                        </Grid>
                                        <Button Content="APPLY THEME" Style="{StaticResource RiotButton}"
                                                Padding="20,10" FontSize="13" HorizontalAlignment="Left"
                                                Click="ApplyTheme_Click"/>
                                    </StackPanel>
                                </Border>

                                <!-- Window Border Toggle -->
                                <Border Background="#15151F" CornerRadius="8" Padding="24" Margin="0,0,0,20">
                                    <StackPanel>
                                        <TextBlock Text="WINDOW BORDER" Foreground="#DC143C" FontSize="11" FontWeight="Bold" Margin="0,0,0,12"/>
                                        <TextBlock Text="Toggle the accent border around the launcher window."
                                                   Foreground="#888888" FontSize="12" Margin="0,0,0,14" TextWrapping="Wrap"/>
                                        <CheckBox x:Name="BorderToggle" Content="Show window border"
                                                  Foreground="White" FontSize="13" Cursor="Hand"
                                                  Checked="BorderToggle_Changed" Unchecked="BorderToggle_Changed"/>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                    <!-- CREDITS VIEW -->
                    <Grid x:Name="CreditsView" Visibility="Collapsed" Style="{StaticResource ContentView}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="CREDITS" FontSize="28" FontWeight="Bold" Foreground="White" Margin="0,0,0,30"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel MaxWidth="600" HorizontalAlignment="Left">
                                <Border Background="#15151F" CornerRadius="8" Padding="30" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="OPERATION THROWBACK" Foreground="#DC143C"
                                                   FontSize="20" FontWeight="Bold" FontFamily="Arial Black" Margin="0,0,0,4"/>
                                        <TextBlock Text="Version 0.2.0" Foreground="#888888" FontSize="13" Margin="0,0,0,4"/>
                                        <TextBlock Text="Created by: Cele D. Luffy" Foreground="White" FontSize="14"/>
                                    </StackPanel>
                                </Border>
                                <Border Background="#15151F" CornerRadius="8" Padding="30" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="SPECIAL THANKS" Foreground="#DC143C" FontSize="11" FontWeight="Bold" Margin="0,0,0,20"/>
                                        <TextBlock Text="Yaakov" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                        <TextBlock Text="For creating SteamRE DepotDownloader + Source code"
                                                   Foreground="#AAAAAA" FontSize="13" Margin="0,3,0,20" TextWrapping="Wrap"/>
                                        <TextBlock Text="JVAV, Verge Poland and SlejmUr" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                        <TextBlock Text="Source Code / Ideas from past downloaders"
                                                   Foreground="#AAAAAA" FontSize="13" Margin="0,3,0,20" TextWrapping="Wrap"/>
                                        <TextBlock Text="Lungu" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                        <TextBlock Text="Creator of amazing tools like ThrowbackLoader, Cracks, R6Liberator and Shears"
                                                   Foreground="#AAAAAA" FontSize="13" Margin="0,3,0,20" TextWrapping="Wrap"/>
                                        <Separator Background="#22222F" Margin="0,0,0,20"/>
                                        <TextBlock Text="R6 Legacy Community" Foreground="White" FontSize="15" FontWeight="Bold"/>
                                        <TextBlock Text="&amp; All Legacy R6 Players" Foreground="#AAAAAA" FontSize="13" Margin="0,3,0,0"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>

                </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>
